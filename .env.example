# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local dev: postgresql://user:password@localhost:5432/peptide_wiki
# Production: use Supabase, Neon, or any managed Postgres
DATABASE_URI=postgresql://user:password@localhost:5432/peptide_wiki

# ── Payload CMS ───────────────────────────────────────────────────────────────
# Random secret — generate with: openssl rand -hex 32
PAYLOAD_SECRET=your-secret-here

# ── PubMed / NCBI ─────────────────────────────────────────────────────────────
# Optional but recommended — increases rate limit from 3 to 10 req/sec
# Register free at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Used for membership billing (Phase 3)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
